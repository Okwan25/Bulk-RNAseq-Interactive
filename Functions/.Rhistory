# -------------------------
# 🔹 1. PARSE SAMPLE NAMES
# -------------------------
parse_samples <- function(samples) {
split_names <- strsplit(samples, "[-_]")
data.frame(
sample = samples,
ID = sapply(split_names, function(x) {
if (length(x) < 2) return(NA)
x[length(x)-1]
}),
condition = sapply(split_names, function(x) {
x[length(x)]
}),
stringsAsFactors = FALSE
)
}
