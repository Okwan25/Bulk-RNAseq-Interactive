parse_sample_names <- function(sample_names) {
# 1. Détection des séparateurs possibles
separators <- c("-", "_", "\\.", "\\|", "/")
detected <- separators[sapply(separators, function(x) {
any(grepl(x, sample_names))
})]
if (length(detected) == 0) {
stop("Aucun séparateur détecté dans les noms d'échantillons")
}
cat("Séparateurs détectés :\n")
print(gsub("\\\\", "", detected))
# Choix du séparateur
sep_choice <- readline(
paste0(
"Quel séparateur utiliser ? ",
paste(gsub("\\\\", "", detected), collapse = ", "),
" : "
)
)
if (!sep_choice %in% gsub("\\\\", "", detected)) {
stop("Séparateur invalide")
}
sep_choice <- ifelse(sep_choice == ".", "\\.", sep_choice)
# 2. Découpage des noms
split_names <- strsplit(sample_names, sep_choice)
# Vérification que tous ont la même longueur
n_parts <- unique(lengths(split_names))
if (length(n_parts) != 1) {
stop("Les noms d'échantillons ne possèdent pas tous le même nombre de champs")
}
annotation <- as.data.frame(do.call(rbind, split_names))
colnames(annotation) <- paste0("part_", seq_len(ncol(annotation)))
# 3. Affichage pour l'utilisateur
cat("\nStructure détectée :\n\n")
print(annotation)
# 4. Demande du rôle de chaque colonne
roles <- character(ncol(annotation))
for (i in seq_len(ncol(annotation))) {
cat("\nColonne", colnames(annotation)[i],
"contient :\n")
print(unique(annotation[,i]))
roles[i] <- readline(
"Nom de cette variable (ex: condition, patient, sample_id) : "
)
}
# 5. Renommer les colonnes
colnames(annotation) <- roles
return(annotation)
}
