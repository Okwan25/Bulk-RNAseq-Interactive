# -------------------------
# 🔹 2. AUTO-DETECT GROUPS
# -------------------------
meta <- annotation_col
conditions <- unique(meta$condition)
cat("\nDetected conditions:\n")
print(conditions)
if (length(conditions) < 2) {
stop("Not enough distinct conditions detected in filenames.")
}
# -------------------------
# 🔹 4bis. SELECT TIMEPOINT PER CONDITION
# -------------------------
possible.variables <- setdiff(colnames(meta), "condition")
if (length(possible.variables) > 0) {
other.variables <- possible.variables[
sapply(meta[possible.variables], function(x) {
length(unique(x)) > 1
})
]
if (length(other.variables) > 0) {
select.variable <- menu(
c("Yes", "No"),
title = "Do you want to select an additional variable (e.g. Day)?"
)
if (select.variable == 1) {
variable <- select.list(
other.variables,
multiple = FALSE,
title = "Select variable to filter"
)
selected.values <- list()
for (cond in dge.condition) {
available.values <- unique(
meta[meta$condition == cond, variable]
)
selected.values[[cond]] <- select.list(
available.values,
multiple = FALSE,
title = paste(
"Select", variable,
"for condition", cond
)
)
}
# Apply filtering
keep <- rep(FALSE, nrow(meta))
for (cond in names(selected.values)) {
keep <- keep |
(
meta$condition == cond &
meta[[variable]] == selected.values[[cond]]
)
}
meta <- meta[keep, ]
cat("\nSelected filtering:\n")
print(selected.values)
}
}
}
