source("../Functions/1.1.start_with_countsData.R")
meta <- annotation_col
conditions <- unique(meta$condition)
cat("\nDetected conditions:\n")
print(conditions)
if (length(conditions) < 2) {
stop("Not enough distinct conditions detected in filenames.")
}
possible.variables <- setdiff(colnames(meta), "condition")
if (length(possible.variables) > 0) {
add.filter <- menu(
c("Yes", "No"),
title = "Do you want to filter samples using another variable?"
)
if (add.filter == 1) {
selected.variables <- select.list(
possible.variables,
multiple = TRUE,
title = "Select additional filtering variable(s)"
)
if (length(selected.variables) > 0) {
filter.criteria <- list()
for (var in selected.variables) {
cat("\nAvailable values for", var, ":\n")
print(unique(meta[[var]]))
selected.values <- select.list(
unique(meta[[var]]),
multiple = TRUE,
title = paste("Select values to keep for", var)
)
filter.criteria[[var]] <- selected.values
}
# Apply filtering
for (var in names(filter.criteria)) {
meta <- meta[
meta[[var]] %in% filter.criteria[[var]],
]
}
}
}
}
